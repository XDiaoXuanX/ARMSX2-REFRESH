+        return "Stretch";
+    if (value == "Auto 4:3/3:2" || value == "1")
+        return "Auto 4:3/3:2";
+    if (value == "4:3" || value == "2")
+        return "4:3";
+    if (value == "16:9" || value == "3")
+        return "16:9";
+    if (value == "10:7" || value == "4")
+        return "10:7";
+    return nullptr;
+}
